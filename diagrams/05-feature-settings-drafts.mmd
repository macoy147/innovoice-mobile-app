---
title: Settings & Draft Management Feature - Detailed Flow
description: How users manage app settings and saved drafts
---

graph TB
    START([User Taps<br/>Settings Tab])
    
    START --> SETTINGS_SCREEN[⚙️ Settings Screen]
    
    %% Settings Sections
    SETTINGS_SCREEN --> SECTIONS[Display Sections]
    
    SECTIONS --> LANG_SECTION[🌍 Language Section]
    SECTIONS --> DRAFT_SECTION[📄 Drafts Section]
    SECTIONS --> ABOUT_SECTION[ℹ️ About Section]
    SECTIONS --> LEGAL_SECTION[📜 Legal Section]
    
    %% Language Section
    LANG_SECTION --> LANG_PICKER[Language Picker<br/>Dropdown]
    LANG_PICKER --> LANG_OPTIONS{Select<br/>Language}
    LANG_OPTIONS -->|English| CHANGE_LANG[🔄 Change Language]
    LANG_OPTIONS -->|Tagalog| CHANGE_LANG
    LANG_OPTIONS -->|Bisaya| CHANGE_LANG
    CHANGE_LANG --> SAVE_LANG[💾 Save to Storage]
    SAVE_LANG --> RELOAD_UI[🔄 Reload UI Text]
    RELOAD_UI --> SUCCESS_TOAST[✅ Success Toast]
    SUCCESS_TOAST --> SETTINGS_SCREEN
    
    %% Drafts Section
    DRAFT_SECTION --> DRAFT_COUNT[📊 Show Draft Count]
    DRAFT_COUNT --> HAS_DRAFTS{Has<br/>Drafts?}
    
    HAS_DRAFTS -->|No| EMPTY_STATE[📭 No Drafts Message]
    EMPTY_STATE --> SETTINGS_SCREEN
    
    HAS_DRAFTS -->|Yes| DRAFT_ACTIONS[Show Action Buttons]
    DRAFT_ACTIONS --> VIEW_BTN[👁️ View Drafts Button]
    DRAFT_ACTIONS --> CLEAR_BTN[🗑️ Clear All Button]
    
    %% View Drafts Flow
    VIEW_BTN --> VIEW_CLICK{User Taps<br/>View Drafts?}
    VIEW_CLICK -->|Yes| OPEN_MODAL[📱 Open Drafts Modal]
    VIEW_CLICK -->|No| WAIT1
    
    OPEN_MODAL --> DRAFTS_LIST[📋 Drafts List]
    DRAFTS_LIST --> LOAD_DRAFTS[⏳ Load from Storage]
    LOAD_DRAFTS --> DISPLAY_DRAFTS[Display Draft Cards]
    
    DISPLAY_DRAFTS --> DRAFT_CARD[Each Draft Shows:<br/>- Category Badge<br/>- Title<br/>- Content Preview<br/>- Date Created<br/>- Photo Indicator]
    
    DRAFT_CARD --> DRAFT_ACTIONS_CARD[Card Actions]
    DRAFT_ACTIONS_CARD --> EDIT_BTN[✏️ Edit Button]
    DRAFT_ACTIONS_CARD --> SUBMIT_BTN[📤 Submit Button]
    DRAFT_ACTIONS_CARD --> DELETE_BTN[🗑️ Delete Button]
    
    %% Edit Draft
    EDIT_BTN --> EDIT_CLICK{User Taps<br/>Edit?}
    EDIT_CLICK -->|Yes| CLOSE_MODAL1[Close Modal]
    CLOSE_MODAL1 --> LOAD_DRAFT[📥 Load Draft Data]
    LOAD_DRAFT --> GO_HOME[🏠 Navigate to Home Tab]
    GO_HOME --> POPULATE_FORM[📝 Populate Form Fields]
    POPULATE_FORM --> EDIT_MODE[✏️ Edit Mode Active]
    EDIT_CLICK -->|No| WAIT2
    
    %% Submit Draft
    SUBMIT_BTN --> SUBMIT_CLICK{User Taps<br/>Submit?}
    SUBMIT_CLICK -->|Yes| VALIDATE_DRAFT{Draft<br/>Valid?}
    VALIDATE_DRAFT -->|No| VALIDATION_ERROR[❌ Show Errors]
    VALIDATION_ERROR --> DRAFTS_LIST
    
    VALIDATE_DRAFT -->|Yes| CHECK_NETWORK{Internet<br/>Connected?}
    CHECK_NETWORK -->|No| OFFLINE_ERROR[🔴 Offline Error]
    OFFLINE_ERROR --> DRAFTS_LIST
    
    CHECK_NETWORK -->|Yes| SUBMIT_DRAFT[📤 Submit to Server]
    SUBMIT_DRAFT --> SUBMIT_SUCCESS{Success?}
    SUBMIT_SUCCESS -->|Yes| DELETE_DRAFT_AUTO[🗑️ Auto-delete Draft]
    DELETE_DRAFT_AUTO --> SHOW_SUCCESS[✅ Success Modal]
    SHOW_SUCCESS --> CLOSE_MODAL2[Close Drafts Modal]
    CLOSE_MODAL2 --> SETTINGS_SCREEN
    
    SUBMIT_SUCCESS -->|No| SUBMIT_ERROR[❌ Submission Error]
    SUBMIT_ERROR --> DRAFTS_LIST
    SUBMIT_CLICK -->|No| WAIT2
    
    %% Delete Single Draft
    DELETE_BTN --> DELETE_CLICK{User Taps<br/>Delete?}
    DELETE_CLICK -->|Yes| DELETE_CONFIRM[⚠️ Confirmation Dialog<br/>Custom Styled]
    DELETE_CONFIRM --> CONFIRM_DELETE{Confirm?}
    CONFIRM_DELETE -->|Yes| DELETE_SINGLE[🗑️ Delete from Storage]
    DELETE_SINGLE --> REFRESH_LIST[🔄 Refresh List]
    REFRESH_LIST --> UPDATE_COUNT[📊 Update Count]
    UPDATE_COUNT --> DRAFTS_LIST
    CONFIRM_DELETE -->|No| DRAFTS_LIST
    DELETE_CLICK -->|No| WAIT2
    
    %% Clear All Drafts
    CLEAR_BTN --> CLEAR_CLICK{User Taps<br/>Clear All?}
    CLEAR_CLICK -->|Yes| CLEAR_CONFIRM[⚠️ Confirmation Dialog<br/>Custom Styled]
    CLEAR_CONFIRM --> CONFIRM_CLEAR{Confirm?}
    CONFIRM_CLEAR -->|Yes| CLEAR_ALL[🗑️ Clear All from Storage]
    CLEAR_ALL --> CLEAR_SUCCESS[✅ Success Toast]
    CLEAR_SUCCESS --> SETTINGS_SCREEN
    CONFIRM_CLEAR -->|No| SETTINGS_SCREEN
    CLEAR_CLICK -->|No| WAIT1
    
    %% About Section
    ABOUT_SECTION --> ABOUT_INFO[Display:<br/>- App Name<br/>- Tagline<br/>- Version<br/>- CTU Logo]
    
    %% Legal Section
    LEGAL_SECTION --> LEGAL_LINKS[Legal Links]
    LEGAL_LINKS --> PRIVACY_LINK[🔒 Privacy Policy]
    LEGAL_LINKS --> TERMS_LINK[📜 Terms of Use]
    
    PRIVACY_LINK --> PRIVACY_CLICK{User Taps<br/>Privacy?}
    PRIVACY_CLICK -->|Yes| PRIVACY_MODAL[📱 Privacy Policy Modal]
    PRIVACY_MODAL --> CLOSE_PRIVACY[Close Button]
    CLOSE_PRIVACY --> SETTINGS_SCREEN
    PRIVACY_CLICK -->|No| WAIT1
    
    TERMS_LINK --> TERMS_CLICK{User Taps<br/>Terms?}
    TERMS_CLICK -->|Yes| TERMS_MODAL[📱 Terms of Use Modal]
    TERMS_MODAL --> CLOSE_TERMS[Close Button]
    CLOSE_TERMS --> SETTINGS_SCREEN
    TERMS_CLICK -->|No| WAIT1
    
    WAIT1[⏰ User Viewing Settings]
    WAIT2[⏰ User Viewing Drafts]
    WAIT1 --> SETTINGS_SCREEN
    WAIT2 --> DRAFTS_LIST
    
    %% Styling
    classDef startEnd fill:#16a34a,stroke:#15803d,stroke-width:3px,color:#fff
    classDef decision fill:#f59e0b,stroke:#d97706,stroke-width:2px,color:#fff
    classDef process fill:#3b82f6,stroke:#1e40af,stroke-width:2px,color:#fff
    classDef error fill:#dc2626,stroke:#991b1b,stroke-width:2px,color:#fff
    classDef success fill:#22c55e,stroke:#16a34a,stroke-width:2px,color:#fff
    classDef storage fill:#8b5cf6,stroke:#6d28d9,stroke-width:2px,color:#fff
    classDef modal fill:#06b6d4,stroke:#0891b2,stroke-width:2px,color:#fff
    
    class START startEnd
    class LANG_OPTIONS,HAS_DRAFTS,VIEW_CLICK,EDIT_CLICK,SUBMIT_CLICK,DELETE_CLICK,CLEAR_CLICK decision
    class VALIDATE_DRAFT,CHECK_NETWORK,SUBMIT_SUCCESS,CONFIRM_DELETE,CONFIRM_CLEAR,PRIVACY_CLICK,TERMS_CLICK decision
    class SETTINGS_SCREEN,SECTIONS,LANG_SECTION,DRAFT_SECTION,ABOUT_SECTION,LEGAL_SECTION process
    class LANG_PICKER,CHANGE_LANG,RELOAD_UI,DRAFT_COUNT,DRAFT_ACTIONS,VIEW_BTN,CLEAR_BTN process
    class DRAFTS_LIST,LOAD_DRAFTS,DISPLAY_DRAFTS,DRAFT_CARD,DRAFT_ACTIONS_CARD process
    class LOAD_DRAFT,GO_HOME,POPULATE_FORM,SUBMIT_DRAFT,REFRESH_LIST,UPDATE_COUNT process
    class VALIDATION_ERROR,OFFLINE_ERROR,SUBMIT_ERROR error
    class SUCCESS_TOAST,SHOW_SUCCESS,CLEAR_SUCCESS success
    class SAVE_LANG,DELETE_SINGLE,DELETE_DRAFT_AUTO,CLEAR_ALL storage
    class OPEN_MODAL,CLOSE_MODAL1,CLOSE_MODAL2,DELETE_CONFIRM,CLEAR_CONFIRM,PRIVACY_MODAL,TERMS_MODAL modal
