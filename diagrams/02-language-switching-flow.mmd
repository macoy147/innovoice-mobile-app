flowchart TD
    Start([User Opens Settings]) --> DisplaySettings[Display Settings Screen]
    DisplaySettings --> ShowLanguageSection[Show Language Section]
    ShowLanguageSection --> LoadCurrent[Load Current Language]
    LoadCurrent --> DisplayPicker[Display Language Picker]
    
    DisplayPicker --> ShowOptions[Show Available Languages]
    ShowOptions --> English[English]
    ShowOptions --> Tagalog[Tagalog]
    ShowOptions --> Bisaya[Bisaya/Cebuano]
    
    English --> UserSelects{User<br/>Selects<br/>Language?}
    Tagalog --> UserSelects
    Bisaya --> UserSelects
    
    UserSelects -->|No Change| End
    UserSelects -->|New Language| ValidateCode{Valid<br/>Language<br/>Code?}
    
    ValidateCode -->|No| ShowError[Show Error Toast]
    ShowError --> End
    
    ValidateCode -->|Yes| TriggerHaptic[Trigger Haptic Feedback]
    TriggerHaptic --> UpdateContext[Update Language Context]
    UpdateContext --> SavePreference[Save to AsyncStorage]
    SavePreference --> UpdateI18n[Update i18n Instance]
    UpdateI18n --> ReRender[Re-render All Components]
    
    ReRender --> UpdateNavigation[Update Navigation Labels]
    UpdateNavigation --> UpdateForms[Update Form Labels]
    UpdateForms --> UpdateMessages[Update Messages]
    UpdateMessages --> UpdateButtons[Update Button Text]
    UpdateButtons --> ShowSuccess[Show Success Toast]
    ShowSuccess --> End([End])
    
    style Start fill:#e1f5e1
    style End fill:#e1f5e1
    style UpdateContext fill:#e3f2fd
    style ShowSuccess fill:#c8e6c9
