---
title: Mobile App - Data Flow Architecture
description: How data flows through the app layers
---

graph TB
    subgraph "Presentation Layer"
        SCREENS[📱 Screens<br/>Home, Track, Settings]
        COMPONENTS[🧩 Components<br/>Forms, Cards, Modals]
    end
    
    subgraph "State Management Layer"
        NETWORK_CTX[📡 NetworkContext<br/>Connection Status]
        LANG_CTX[🌍 LanguageContext<br/>i18n Translations]
        APP_CTX[📦 AppContext<br/>Global Config & Drafts]
        TOAST_CTX[🔔 ToastContext<br/>Notifications]
    end
    
    subgraph "Service Layer"
        API_SERVICE[🌐 ApiService<br/>HTTP Client]
        DRAFT_SERVICE[💾 DraftService<br/>Draft CRUD]
        STORAGE_SERVICE[📦 StorageService<br/>AsyncStorage Wrapper]
        IMAGE_SERVICE[📷 ImageService<br/>Image Picker & Processing]
    end
    
    subgraph "External APIs"
        BACKEND[🖥️ Backend API<br/>Express Server]
        NETINFO[📡 NetInfo<br/>Network Monitor]
        ASYNC_STORAGE[(📦 AsyncStorage<br/>Device Storage)]
        IMAGE_PICKER[📷 expo-image-picker<br/>Camera/Gallery]
    end
    
    %% User Interaction Flow
    SCREENS --> COMPONENTS
    COMPONENTS --> NETWORK_CTX
    COMPONENTS --> LANG_CTX
    COMPONENTS --> APP_CTX
    COMPONENTS --> TOAST_CTX
    
    %% Context to Service Flow
    NETWORK_CTX --> API_SERVICE
    APP_CTX --> DRAFT_SERVICE
    COMPONENTS --> API_SERVICE
    COMPONENTS --> DRAFT_SERVICE
    COMPONENTS --> IMAGE_SERVICE
    
    %% Service to External Flow
    API_SERVICE -->|HTTP Requests| BACKEND
    DRAFT_SERVICE --> STORAGE_SERVICE
    STORAGE_SERVICE --> ASYNC_STORAGE
    IMAGE_SERVICE --> IMAGE_PICKER
    
    %% Network Monitoring
    NETINFO -.->|Connection Events| NETWORK_CTX
    
    %% Data Flow Examples
    BACKEND -->|JSON Response| API_SERVICE
    API_SERVICE -->|Parsed Data| COMPONENTS
    ASYNC_STORAGE -->|Stored Data| STORAGE_SERVICE
    STORAGE_SERVICE -->|Retrieved Data| DRAFT_SERVICE
    DRAFT_SERVICE -->|Draft Objects| APP_CTX
    APP_CTX -->|State Updates| COMPONENTS
    IMAGE_PICKER -->|Image Data| IMAGE_SERVICE
    IMAGE_SERVICE -->|Base64 String| COMPONENTS
    
    %% Toast Notifications
    API_SERVICE -.->|Success/Error| TOAST_CTX
    DRAFT_SERVICE -.->|Success/Error| TOAST_CTX
    TOAST_CTX -.->|Display Toast| SCREENS
    
    %% Styling
    classDef presentation fill:#dc2626,stroke:#991b1b,stroke-width:2px,color:#fff
    classDef context fill:#f59e0b,stroke:#d97706,stroke-width:2px,color:#fff
    classDef service fill:#3b82f6,stroke:#1e40af,stroke-width:2px,color:#fff
    classDef external fill:#8b5cf6,stroke:#6d28d9,stroke-width:2px,color:#fff
    
    class SCREENS,COMPONENTS presentation
    class NETWORK_CTX,LANG_CTX,APP_CTX,TOAST_CTX context
    class API_SERVICE,DRAFT_SERVICE,STORAGE_SERVICE,IMAGE_SERVICE service
    class BACKEND,NETINFO,ASYNC_STORAGE,IMAGE_PICKER external
