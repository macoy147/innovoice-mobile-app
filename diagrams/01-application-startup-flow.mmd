flowchart TD
    Start([App Launch]) --> LoadFonts[Load Fonts]
    LoadFonts --> CheckOnboarding{Onboarding<br/>Completed?}
    
    CheckOnboarding -->|No| ShowOnboarding[Show Onboarding Screen]
    ShowOnboarding --> CompleteOnboarding[User Completes Onboarding]
    CompleteOnboarding --> SaveOnboarding[Save Onboarding Status]
    SaveOnboarding --> InitContexts
    
    CheckOnboarding -->|Yes| InitContexts[Initialize Context Providers]
    InitContexts --> ErrorBoundary[Wrap in Error Boundary]
    ErrorBoundary --> NetworkProvider[Initialize Network Provider]
    NetworkProvider --> LanguageProvider[Initialize Language Provider]
    LanguageProvider --> AppProvider[Initialize App Provider]
    AppProvider --> ToastProvider[Initialize Toast Provider]
    
    ToastProvider --> CheckNetwork{Network<br/>Connected?}
    CheckNetwork -->|Yes| EstimateSpeed[Estimate Network Speed]
    CheckNetwork -->|No| SetOffline[Set Offline Mode]
    
    EstimateSpeed --> ShowLoadingScreen[Show Network Loading Screen]
    SetOffline --> ShowLoadingScreen
    
    ShowLoadingScreen --> LoadDrafts[Load Saved Drafts]
    LoadDrafts --> LoadLanguage[Load Language Preference]
    LoadLanguage --> LoadTrackingCodes[Load Saved Tracking Codes]
    LoadTrackingCodes --> HideSplash[Hide Splash Screen]
    HideSplash --> ShowMainApp[Show Main App - Tab Navigation]
    ShowMainApp --> End([Ready])
    
    style Start fill:#e1f5e1
    style End fill:#e1f5e1
    style ShowOnboarding fill:#fff4e6
    style ShowLoadingScreen fill:#e3f2fd
    style ShowMainApp fill:#f3e5f5
